# Discord Webhook URL
# Discord サーバーのチャンネル設定から Webhook を作成してここに貼り付ける
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxx/xxxxxxxxx

# Google AdSense アカウント ID (未設定の場合はメタタグを出力しない)
GOOGLE_ADSENSE_ACCOUNT=

# GitHub Personal Access Token (スコープ不要 / public リポジトリのピン留め取得用)
# 未設定の場合は content.ts の静的 WORKS にフォールバック
GITHUB_TOKEN=
